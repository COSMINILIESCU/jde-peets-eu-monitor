{
  "permissions": {
    "allow": [
      "Bash(python -m pytest*)",
      "Bash(python -m ruff*)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)"
    ],
    "deny": [
      "Read(./.env)",
      "Edit(./.env)",
      "Write(./.env)",
      "Edit(./data/**)",
      "Write(./data/**)",
      "Edit(./.git/**)",
      "Write(./.git/**)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python \"%CLAUDE_PROJECT_DIR%\\scripts\\hooks\\post_edit.py\""
          }
        ]
      }
    ]
  }
}
