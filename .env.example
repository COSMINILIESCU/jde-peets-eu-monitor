# Copy to .env and fill in. NEVER commit .env.
# No API keys are required in the default setup (Claude Code headless uses your login).

# Optional: override the AI model used for analysis (default in config/settings.yaml)
# MONITOR_AI_MODEL=claude-haiku-4-5

# Optional: switch to Anthropic API instead of Claude Code subscription (future migration)
# ANTHROPIC_API_KEY=

# Git remote used for publishing (set automatically by setup, e.g. origin)
# MONITOR_GIT_REMOTE=origin
